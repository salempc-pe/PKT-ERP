rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para obtener el organizationId del usuario actual
    // IMPORTANTE: El documento del usuario en /users debe tener como ID el UID de Firebase Auth
    function getUserOrg() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId;
    }

    // Función para verificar si el usuario es Super Admin del SaaS
    function isSuperAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Colección de Usuarios ---
    match /users/{userId} {
      // El usuario puede leer y escribir su propio perfil. El Super Admin tiene acceso total.
      allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
    }

    // --- Colección de Organizaciones (Multi-tenancy) ---
    match /organizations/{orgId} {
      // Lectura si el usuario pertenece a la organización o es Super Admin
      allow read: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      // Escritura (crear/editar/eliminar org) solo para Super Admin
      allow write: if request.auth != null && isSuperAdmin();

      // --- Subcolecciones de la Organización ---
      // (contacts, leads, inventory, sales, projects, finance, etc.)
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
    }

    // --- Logs y Auditoría ---
    match /activity_logs/{logId} {
      allow read: if request.auth != null && (getUserOrg() == resource.data.organizationId || isSuperAdmin());
      allow write: if request.auth != null; // Se permite escritura pero las reglas de validación podrían ser más estrictas
    }

    // --- Alertas de Sistema ---
    match /system_alerts/{alertId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }
  }
}
