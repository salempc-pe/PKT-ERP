rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regla base: Permite lectura y escritura si el usuario está autenticado
    // Esto es solo para empezar, deberás ajustar las reglas según tu lógica de negocio
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
