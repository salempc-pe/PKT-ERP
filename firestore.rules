rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función segura para verificar si un documento existe antes de leerlo
    function userExists() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Función auxiliar para obtener el organizationId del usuario actual
    function getUserOrg() {
      return (request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('organizationId', null)
        : null;
    }

    // Función para verificar si el usuario es Super Admin del SaaS (Gestiona todo)
    function isSuperAdmin() {
      return (request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid))) && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'superadmin' ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin' && 
         !('organizationId' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data))
      );
    }

    // Función para verificar si el usuario es administrador de SU propia organización
    function isOrgAdmin() {
      return (request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid))) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin' && 
        'organizationId' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // --- Colección de Usuarios ---
    match /users/{userId} {
      // Lectura individual permitida para el propio usuario o el Super Admin
      allow read: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      
      // Crear/Actualizar permitido: 
      // 1. El propio usuario (solo sus datos)
      // 2. El Org Admin de su organización (para gestionar equipo)
      // 3. El Super Admin (para soporte)
      // 4. Usuario sin auth activando su cuenta (Onboarding)
      allow create, update: if (request.auth != null && (
        request.auth.uid == userId || 
        isSuperAdmin() || 
        (isOrgAdmin() && getUserOrg() == request.resource.data.organizationId) ||
        (isOrgAdmin() && getUserOrg() == resource.data.organizationId)
      )) || (
        // Permiso especial para la activación de cuenta
        (resource == null || resource.data.status == 'pending') && 
        request.resource.data.status == 'active'
      );

      // Eliminar permitido:
      // 1. Super Admin
      // 2. Proceso de Onboarding (para eliminar el documento temporal una vez usado el token)
      allow delete: if (request.auth != null && (request.auth.uid == userId || isSuperAdmin())) || (
        resource.data.status == 'pending' && resource.data.inviteToken != null
      );
      
      // Listado permitido:
      // 1. Super Admin o admin de la misma organización
      // 2. Usuario sin auth buscando su propio token de invitación (Onboarding)
      allow list: if (request.auth != null && (
        isSuperAdmin() || 
        (getUserOrg() != null && resource.data.organizationId == getUserOrg())
      )) || (
        // Permitir buscar por token si el estado es pendiente
        resource.data.status == 'pending' && resource.data.inviteToken != null
      );
    }

    // --- Colección de Organizaciones (Multi-tenancy) ---
    match /organizations/{orgId} {
      // Lectura si el usuario pertenece a la organización o es Super Admin
      allow read: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      
      // Escritura (crear/editar/eliminar org) solo para Super Admin
      allow write: if isSuperAdmin();

      // --- Subcolecciones de la Organización ---
      
      // CRM: Contactos, Leads e Interacciones
      match /contacts/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /leads/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /interactions/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      
      // Inventario
      match /inventory/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /products/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /warehouses/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /inventory_transfers/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /inventory_transactions/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      
      // Ventas y Facturación
      match /invoices/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      
      // Finanzas: Transacciones
      match /transactions/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      
      // Calendario: Citas
      match /appointments/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      
      // Proyectos, Tareas, Timesheets y Documentos
      match /projects/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /tasks/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /timesheets/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /project_documents/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      
      // Compras: Proveedores y Órdenes
      match /suppliers/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /purchases/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      
      // Real Estate: Terrenos y Pipeline
      match /realEstateTerrains/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /pipeline/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      
      match /realEstateInvestors/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      
      // Bodega / Warehouse
      match /warehouse_stock/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /warehouse_history/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      
      // Nóminas: Empleados
      match /employees/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }

      // Módulo Salud / Clínicas
      match /expedientes/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /citas/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /notas_sesion/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /notas_generales/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
      match /archivos_paciente/{docId} {
        allow read, write: if request.auth != null && (getUserOrg() == orgId || isSuperAdmin());
      }
    }

    // --- Logs y Auditoría ---
    match /audit_logs/{logId} {
      allow read: if request.auth != null && (getUserOrg() == resource.data.orgId || isSuperAdmin());
      allow write: if request.auth != null && (getUserOrg() == request.resource.data.orgId || isSuperAdmin());
    }

    // --- Alertas de Sistema ---
    match /system_alerts/{alertId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // --- Feedback de Usuarios ---
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read: if isSuperAdmin();
    }
  }
}
